#!/bin/sh
set -eu

remote_name="${1:-origin}"
remote_url="${2:-}"
repo_root="$(git rev-parse --show-toplevel)"
version_file="Firmware/GPAD_API/FIRMWARE_VERSION"

has_firmware_push=0
version_already_in_push=0
while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    continue
  fi
  case "$local_ref" in
    refs/heads/*|HEAD)
      has_firmware_push=1
      ;;
  esac

  if [ "$remote_sha" != "0000000000000000000000000000000000000000" ] &&
    git diff --quiet "$remote_sha..$local_sha" -- "$version_file"; then
    :
  else
    version_already_in_push=1
  fi
done

if [ "$has_firmware_push" -eq 0 ]; then
  exit 0
fi

if [ "$version_already_in_push" -eq 1 ]; then
  exit 0
fi

cd "$repo_root"

if ! git diff --quiet -- "$version_file" || ! git diff --cached --quiet -- "$version_file"; then
  echo "GPAD firmware version is already modified. Commit it before pushing." >&2
  exit 1
fi

if ! git diff --cached --quiet; then
  echo "There are staged changes. Commit or unstage them before the GPAD version hook runs." >&2
  exit 1
fi

python3 scripts/bump_gpad_firmware_version.py

if git diff --quiet -- "$version_file"; then
  exit 0
fi

git add "$version_file"
git commit -m "Bump GPAD firmware version"

echo "Created a GPAD firmware version commit for ${remote_name} ${remote_url}." >&2
echo "Re-run git push to send your code with the new firmware version." >&2
exit 1
